{
    "manifest_version": 3,
    "name": "Wide Theme Gemini",
    "version": "1.1.0",
    "description": "Adjust the width of Google Gemini's chat interface with a draggable slider.",
    "content_scripts": [
      {
        "matches": ["https://gemini.google.com/*"],
        "js": ["Content.js"]
      }
    ],

    "icons": {
        "16": "logo.png",
        "48": "logo.png",
        "128": "logo.png"
      }
  }


  